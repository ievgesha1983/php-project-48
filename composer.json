{
    "name": "differ/differ",
    "description": "Difference calculator",
    "type": "project",
    "license": "MIT",
    "bin": [
        "bin/gendiff"
    ],
    "autoload": {
        "psr-4": {
            "Differ\\": "src/",
            "Differ\\Tests\\": "tests/"
        },
        "files": [
            "config/config.php",
            "src/Functions.php",
            "src/differ.php"
        ]
    },
    "authors": [
        {
            "name": "Evgenii Ivanov",
            "email": "ievgesha@mail.ru"
        }
    ],
    "require": {
        "docopt/docopt": "^1.0",
        "funct/funct": "^1.6",
        "symfony/yaml": "^7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "squizlabs/php_codesniffer": "^4.0"
    }
}
