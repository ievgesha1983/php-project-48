#!/usr/bin/env php

<?php

$autoload1 = __DIR__ . "/../vendor/autoload.php";
$autoload2 = __DIR__ . "/../../../autoload.php";

if (file_exists($autoload1)) {
    require_once $autoload1;
} else {
    require_once $autoload2;
}

use Docopt\Handler;
const DOC = "
Generate diff

Usage:
  gendiff (-h|--help)
  gendiff (-v|--version)

Options:
  -h --help                     Show this screen
  -v --version                  Show version
";

$handler = new Handler();
$handler->handle(DOC);
