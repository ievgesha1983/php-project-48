#!/usr/bin/env php

<?php

const DOC =
"Generate diff

Usage:
  gendiff (-h|--help)
  gendiff (-v|--version)
  gendiff [--format <fmt>] <firstFile> <secondFile>
  gendiff -hal
  
Options:
  -h --help                     Show this help
  -v --version                  Show version
  -hal                          Test
  --format <fmt>                Report format [default: stylish]
";

$autoload1 = __DIR__ . "/../vendor/autoload.php";
$autoload2 = __DIR__ . "/../../../autoload.php";

if (file_exists($autoload1)) {
    require_once $autoload1;
} else {
    require_once $autoload2;
}

use Docopt\Handler;
const DOC = "
Generate diff

Usage:
  gendiff (-h|--help)
  gendiff (-v|--version)

$args = Docopt::handle(DOC, ['version' => 'Generate deff 0.0.1']);

$handler = new Handler();
$handler->handle(DOC);
