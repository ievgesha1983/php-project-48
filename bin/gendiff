#!/usr/bin/env php

<?php

const DOC =
"Generate diff

Usage:
  gendiff (-h|--help)
  gendiff (-v|--version)
  gendiff [--format <fmt>] <firstFile> <secondFile>
  
Options:
  -h --help                     Show this help
  -v --version                  Show version
  --format <fmt>                Report format [default: stylish]
";
const DOCOPT_CONFIG = [
    'version' => 'Generate deff 0.0.1'
];
const FORMAT_TYPES = ['stylish'];
const FILE_TYPES = ['json'];

$autoload1 = __DIR__ . "/../vendor/autoload.php";
$autoload2 = __DIR__ . "/../../../autoload.php";

if (file_exists($autoload1)) {
    require_once $autoload1;
} else {
    require_once $autoload2;
}

use Hexlet\Code\DifferenceProcessor;

$docopt = Docopt::handle(DOC, DOCOPT_CONFIG);

var_dump($docopt->args);