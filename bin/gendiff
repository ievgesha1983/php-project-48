#!/usr/bin/env php
<?php


$autoload1 = __DIR__ . "/../vendor/autoload.php";
$autoload2 = __DIR__ . "/../../../autoload.php";

if (file_exists($autoload1)) {
    require_once $autoload1;
} else {
    require_once $autoload2;
}

use Differ\DifferenceProcessor;

$config = require(__DIR__ . "/../config/config.php");

$docopt = Docopt::handle($config['docoptScheme'], $config['docoptConfig']);

echo DifferenceProcessor::getDiffInfo($docopt->args) . PHP_EOL;
